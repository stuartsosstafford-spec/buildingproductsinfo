---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';
import { buildCanonical } from '@/lib/seo';
import { categories } from '@/lib/categories';

const guides = await getCollection('guides', ({ data }) => !data.draft);
guides.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const breadcrumbs = [
  { name: 'Guides', url: buildCanonical('/guides/') },
];

// Group guides by category, preserving the canonical category order
const categoryOrder = categories.map((c) => c.label);
const guidesByCategory: Record<string, typeof guides> = {};

for (const guide of guides) {
  const cat = guide.data.category ?? 'General';
  if (!guidesByCategory[cat]) guidesByCategory[cat] = [];
  guidesByCategory[cat].push(guide);
}

// Build ordered list of categories that actually have guides
const orderedCategories = [
  ...categoryOrder.filter((c) => guidesByCategory[c]),
  ...Object.keys(guidesByCategory).filter((c) => !categoryOrder.includes(c)),
];

// Find matching category icon
const categoryMeta = Object.fromEntries(categories.map((c) => [c.label, c]));
---
<BaseLayout
  title="Buying Guides"
  description="Expert buying guides for building and trade products. Practical advice to help you choose the right products for the job."
>
  <div class="container">
    <Breadcrumbs items={breadcrumbs} />

    <h1>Buying Guides</h1>
    <p style="margin-bottom:2rem;color:var(--color-text-light);">
      Practical buying guides and product advice for trade professionals and serious DIYers.
      Browse by category or scroll to find what you need.
    </p>

    {guides.length === 0 && (
      <p>No guides published yet. Check back soon.</p>
    )}

    {guides.length > 0 && (
      <>
        {/* Category filter pills */}
        <nav class="guide-filter" aria-label="Filter guides by category">
          {orderedCategories.map((cat) => {
            const meta = categoryMeta[cat];
            const slug = cat.toLowerCase().replace(/[^a-z0-9]+/g, '-');
            return (
              <a href={`#${slug}`} class="guide-filter-pill">
                {meta?.icon && <span>{meta.icon}</span>}
                {cat}
                <span class="guide-filter-count">{guidesByCategory[cat].length}</span>
              </a>
            );
          })}
        </nav>

        {/* Guides grouped by category */}
        {orderedCategories.map((cat) => {
          const meta = categoryMeta[cat];
          const slug = cat.toLowerCase().replace(/[^a-z0-9]+/g, '-');
          const catGuides = guidesByCategory[cat];
          return (
            <section class="guide-category-section" id={slug}>
              <div class="guide-category-heading">
                {meta?.icon && <span class="guide-category-icon">{meta.icon}</span>}
                <h2>{cat}</h2>
                {meta && (
                  <a href={`/${meta.slug}/`} class="guide-category-link">
                    Browse {cat} products &rarr;
                  </a>
                )}
              </div>
              <div class="product-grid">
                {catGuides.map((guide) => {
                  const date = new Date(guide.data.publishDate).toLocaleDateString('en-GB', {
                    year: 'numeric', month: 'short', day: 'numeric',
                  });
                  return (
                    <article class="product-card">
                      {guide.data.featuredImage && (
                        <div class="product-card-image">
                          <a href={`/guides/${guide.slug}/`}>
                            <img src={guide.data.featuredImage} alt={guide.data.title} loading="lazy" width="400" height="300" />
                          </a>
                        </div>
                      )}
                      <div class="product-card-body">
                        <h3 class="product-card-title">
                          <a href={`/guides/${guide.slug}/`}>{guide.data.title}</a>
                        </h3>
                        <p class="product-card-brand">{date} &middot; {guide.data.author}</p>
                      </div>
                    </article>
                  );
                })}
              </div>
            </section>
          );
        })}
      </>
    )}
  </div>
</BaseLayout>
