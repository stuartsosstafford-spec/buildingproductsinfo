---
import { getCollection } from 'astro:content';

interface Props {
  categoryLabel: string;
}

const { categoryLabel } = Astro.props;

const allGuides = await getCollection('guides', ({ data }) => !data.draft);
const guides = allGuides
  .filter((g) => g.data.category === categoryLabel)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---
{guides.length > 0 && (
  <section class="category-guides">
    <h2>Buying Guides & Advice</h2>
    <div class="category-guides-grid">
      {guides.map((guide) => (
        <a href={`/guides/${guide.slug}/`} class="category-guide-card">
          <span class="category-guide-label">Guide</span>
          <span class="category-guide-title">{guide.data.title}</span>
          <span class="category-guide-arrow">&rarr;</span>
        </a>
      ))}
    </div>
  </section>
)}
